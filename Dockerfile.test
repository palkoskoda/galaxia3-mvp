# Test Dockerfile - Rovnaké prostredie ako Render
FROM node:20.11.0-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./
COPY backend/package*.json ./backend/
COPY frontend/package*.json ./frontend/

# Install dependencies (ako Render)
RUN npm ci && \
    cd backend && npm ci && \
    cd ../frontend && npm ci

# Copy source
COPY . .

# Build (ako Render)
RUN cd backend && npm run build && \
    cd ../frontend && npm run build

# Test start
RUN cd backend && timeout 5s npm start || true

CMD ["echo", "Build test passed!"]
